{
    "name": "uniforcemusic/notitioner-mcp",
    "description": "MCP server that offers note taking functionality for LLMs. Compatible with major databases",
    "authors": [
        {
            "name": "uniforcemusic"
        }
    ],
    "autoload": {
        "psr-4": {
            "Src\\": "src"
        }
    },
    "require": {
        "php": "^8.3",
        "mcp/sdk": "^0.5.0",
        "sentience/database": "^2.13",
        "vlucas/phpdotenv": "^5.6"
    },
    "config": {
        "allow-plugins": {
            "php-http/discovery": true
        }
    }
}
